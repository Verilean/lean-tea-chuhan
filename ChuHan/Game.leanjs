-- examples/ChuHan/Game.leanjs — 楚漢恋歌 game logic (LeanJs subset)
--
-- Architecture
-- ────────────
--   state    : everything mutable. Phase / character / scene cursor /
--              stats / flags / battle entities. Persisted to localStorage.
--   update   : (msg, state) -> state.  Pure dispatch on msg.tag.
--   view     : state -> HTML string. Phase decides which renderer fires.
--
-- All player-facing strings carry both `ja` and `en` keys; empty `en`
-- falls back to `ja`. The lang picker lives in the persistent HUD.
--
-- LLM hooks are stubbed — `askNpc` would POST to /api/ask but for the
-- MVP we surface a placeholder so the wiring is visible.

-- ── FFI primitives ──────────────────────────────────────────────────
extern js "(n) => Array(n).fill(0)" mkArray
extern js "(arr, i, v) => arr.map((x, j) => j === i ? v : x)" arrSet
extern js "(arr, i) => arr[i]" arrGet
extern js "(arr) => arr.length" arrLen
extern js "(arr, v) => [...arr, v]" arrPush
extern js "(arr, n) => arr.slice(0, n)" arrSliceHead
extern js "(a, b) => '' + a + b" sconcat
extern js "(a, b) => (a / b) | 0" idiv
extern js "JSON.stringify" jstr
extern js "(s) => String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')" hesc
-- Concatenate an array of strings — cleaner than nesting sconcat.
extern js "(arr) => arr.join('')" sjoin
extern js "() => Math.floor(Math.random() * 1000000)" rngInt
extern js "(a, b) => a < b ? a : b" minI
extern js "(a, b) => a > b ? a : b" maxI
-- 正規表現テスト（最終ログの雰囲気判定などに使う。1 = 一致）。
extern js "(s, re) => new RegExp(re).test(s) ? 1 : 0" reTest

-- ── Save-slot extern bridge ────────────────────────────────────────
-- Browser APIs we need extern access to for save/load logic that
-- otherwise had to live in page.html. Keeping the shape thin —
-- JS-side wrappers stay tiny.
extern js "(key) => { try { return JSON.parse(localStorage.getItem(key) || 'null'); } catch (_) { return null; } }" lsLoad
extern js "(key, v) => { try { localStorage.setItem(key, JSON.stringify(v)); } catch (_) {} }" lsSave
extern js "(key) => { try { localStorage.removeItem(key); } catch (_) {} }" lsRemove
-- Server-backed save slots (SQLite): the label cache + save code are
-- maintained by runtime.js; the menu view reads them through these.
extern js "(n) => (typeof window !== 'undefined' && window.chuhanSlotLabel) ? window.chuhanSlotLabel(n) : '…'" serverSlotLabel
extern js "() => (typeof window !== 'undefined' && window.chuhanGetSaveCode) ? window.chuhanGetSaveCode() : '----'" getSaveCodeStr

-- Ending tracker (for the gallery / trophies). Stores a flat object
-- of {endingId: timestamp} in localStorage 'chuhan-endings'.
extern js "(id) => { try { const cur = JSON.parse(localStorage.getItem('chuhan-endings') || '{}'); cur[id] = Date.now(); localStorage.setItem('chuhan-endings', JSON.stringify(cur)); } catch (_) {} }" lsRecordEnding
extern js "() => { try { return JSON.parse(localStorage.getItem('chuhan-endings') || '{}'); } catch (_) { return {}; } }" lsAllEndings
extern js "(obj, k) => Object.prototype.hasOwnProperty.call(obj, k) ? 1 : 0" hasKey

-- ── Audio bridge ───────────────────────────────────────────────────
-- Two crossfading <audio> tags managed by chuhanAudio in page.html.
-- audioPlay is idempotent: passing the same id back-to-back is a no-op,
-- so we can safely call it on every scene render without restarting
-- the track. id "" stops playback.
extern js "(id) => { try { window.chuhanAudio && window.chuhanAudio.play(id); } catch (_) {} }" audioPlay
extern js "(id) => { try { window.chuhanAudio && window.chuhanAudio.sfx(id); } catch (_) {} }" audioSfx
extern js "() => { try { window.chuhanAudio && window.chuhanAudio.toggleMute(); } catch (_) {} }" audioToggleMute
extern js "() => { try { return window.chuhanAudio && window.chuhanAudio.muted() ? 1 : 0; } catch (_) { return 0; } }" audioIsMuted

-- ── i18n helper ─────────────────────────────────────────────────────
-- A localised string is `{ja: "…", en: "…"}`. `tr` picks the requested
-- language and falls back to `ja` when the target is empty.
def tr(s, lang) :=
  let en := s.en;
  let ja := s.ja;
  if lang == "en" then (if en == "" then ja else en) else ja


-- ── Story content (roster + scenes + scene lookup) ────────────────
include "Story.leanjs"

-- ── State ───────────────────────────────────────────────────────────
record Stats where
  hp : Int, maxHp : Int,
  bu : Int, zhi : Int, mei : Int, zheng : Int,
  karma : Int,
  wife : Int, wifeFear : Int,
  trust : Int, minXin : Int,
  year : Int

def initStats := Stats {
  hp: 100, maxHp: 100,
  bu: 5, zhi: 5, mei: 5, zheng: 5,
  karma: 0, wife: 0, wifeFear: 0,
  trust: 0, minXin: 0,
  year: -209
}

record Battle where
  entities : Array, fx : Array,
  log : String

record Entity where
  kind : String,         -- "player" | "enemy"
  x : Int, y : Int,
  hp : Int, maxHp : Int,
  color : String,
  facingDx : Int, facingDy : Int,
  cooldown : Int,
  speed : Int

record Fx where
  x : Int, y : Int, r : Int, ttl : Int

def initBattle := Battle {
  entities: [],
  fx: [],
  log: ""
}

-- ── Mini-game state ────────────────────────────────────────────────
record Mini where
  kind : String,            -- "" | "face_read" | "jade_ring" | "beishui"
  -- face_read
  faceEyes : Int,           -- 0..2 (穏 / 普 / 鋭)
  faceMouth : Int,          -- 0..2 (真剣 / 普 / 笑)
  facePose : Int,           -- 0..2 (卑屈 / 普 / 堂々)
  faceShown : Bool,         -- has player submitted?
  faceScore : Int,          -- after submit (0..6)
  -- jade_ring
  ringNowMs : Int,          -- elapsed since start of mini
  ringRound : Int,          -- 0..2 (current round)
  ringHits : Int,           -- count of correctly timed clicks
  ringRoundStartMs : Int,   -- when this round began
  ringClickedThisRound : Bool,
  ringFinished : Bool,
  -- beishui — sequential card mini, visualized as 3-turn battle
  bsTurn : Int,             -- 0..3
  bsHanHp : Int,            -- 0..100
  bsZhaoHp : Int,           -- 0..200
  bsScore : Int,            -- accumulated points
  bsLog1 : String, bsLog2 : String, bsLog3 : String,
  bsFinished : Bool

def initMini := Mini {
  kind: "",
  faceEyes: 1, faceMouth: 1, facePose: 1,
  faceShown: false, faceScore: 0,
  ringNowMs: 0, ringRound: 0, ringHits: 0,
  ringRoundStartMs: 0, ringClickedThisRound: false, ringFinished: false,
  bsTurn: 0, bsHanHp: 100, bsZhaoHp: 200,
  bsScore: 0, bsLog1: "", bsLog2: "", bsLog3: "", bsFinished: false
}

def initMiniFor(kind) := Mini {
  kind: kind,
  faceEyes: 1, faceMouth: 1, facePose: 1,
  faceShown: false, faceScore: 0,
  ringNowMs: 0, ringRound: 0, ringHits: 0,
  ringRoundStartMs: 0, ringClickedThisRound: false, ringFinished: false,
  bsTurn: 0, bsHanHp: 100, bsZhaoHp: 200,
  bsScore: 0, bsLog1: "", bsLog2: "", bsLog3: "", bsFinished: false
}

-- ── LLM-driven NPC chat state ──────────────────────────────────────
record Llm where
  active : Bool,
  npcId : String,           -- e.g. "xiaohe"
  npcName : String,         -- display name
  npcColor : String,        -- sprite color
  history : Array,          -- list of {role: "user"|"assistant", text: ...}
  pending : Bool,           -- waiting for /api/ask response
  sceneAfter : String,      -- scene id to goto on "終わる"
  lastError : String        -- last network/LLM error, "" if none

def initLlm := Llm {
  active: false, npcId: "", npcName: "", npcColor: "",
  history: [], pending: false, sceneAfter: "", lastError: ""
}

-- LocalStorage keys for save system.
def lsKeyMain := "chuhan-save-v2"
def lsKeyCheckpoint := "chuhan-checkpoint"
def lsKeySlot(n) := sjoin(["chuhan-slot-", jstr(n)])

-- Render a one-line state preview for save-slot UI labels.
def describeState(s) :=
  if s == null then "(空)"
  else if s.phase == "title" then "タイトル"
  else
    let charName := if s.char == "liubang" then "劉邦"
                    else if s.char == "xiangyu" then "項羽"
                    else if s.char == "hanxin" then "韓信"
                    else if s.char == "zhangliang" then "張良"
                    else if s.char == "xiaohe" then "蕭何"
                    else if s.char == "fanzeng" then "范増"
                    else "?";
    sjoin([charName, " · ", s.sceneId, " · beat ", jstr(s.beat)])

def npcMetaName(id) :=
  if id == "xiaohe" then "蕭何"
  else if id == "luwen" then "呂公"
  else if id == "luzhi" then "呂雉"
  else if id == "fankuai" then "樊噲"
  else if id == "fanzeng" then "范増"
  else if id == "xiangbo" then "項伯"
  else if id == "kuaitong" then "蒯通"
  else if id == "huangshi" then "黄石公"
  else if id == "miaorong" then "妙容"
  else "?"

def npcMetaColor(id) :=
  if id == "xiaohe" then "#5a3a6a"
  else if id == "luwen" then "#4a3a2a"
  else if id == "luzhi" then "#a08060"
  else if id == "fankuai" then "#6a4a2a"
  else if id == "fanzeng" then "#3a5a3a"
  else if id == "xiangbo" then "#5a3a3a"
  else if id == "kuaitong" then "#4a6a4a"
  else if id == "huangshi" then "#a08070"
  else if id == "miaorong" then "#7a5a8a"
  else "#5a5a5a"

def initLlmFor(npcId, sceneAfter) := Llm {
  active: true, npcId: npcId,
  npcName: npcMetaName(npcId),
  npcColor: npcMetaColor(npcId),
  history: [], pending: false, sceneAfter: sceneAfter, lastError: ""
}

-- ── TRPG aiResolve infrastructure ──────────────────────────────────
-- Each resolve "kind" pairs a situation prompt (shown to the player as
-- the scene context) with a 3-way outcome → scene routing table that
-- the LLM's verdict triggers. Keep all kinds defined here so it's one
-- file to scan when designing alt-history forks.

record Resolve where
  active : Bool,
  kind : String,
  situationJa : String, situationEn : String,
  -- routing on outcome
  gotoGood : String,
  gotoOk : String,
  gotoBad : String,
  -- backend round-trip
  playerText : String,     -- echoed back when the result lands
  pending : Bool,
  lastError : String,
  resultOutcome : String,  -- "" | "good" | "ok" | "bad"
  resultReasoning : String -- LLM's narration of why

def initResolve := Resolve {
  active: false, kind: "",
  situationJa: "", situationEn: "",
  gotoGood: "", gotoOk: "", gotoBad: "",
  playerText: "", pending: false, lastError: "",
  resultOutcome: "", resultReasoning: ""
}

-- Situation prompt shown to the player as the framing for their free-text
-- action. The LLM also receives this on the server side so it can judge.
def aiResolveSituationJa(kind) :=
  if kind == "liubang_hongmen_apology" then
    "鴻門。項羽の本陣。 范増の眼は炯々と光り、項荘は剣を抜いて舞っている。\
あなた (劉邦) は今、項羽の前で詫びを述べねばならない。\
言葉ひとつで命運が決まる。\
\n\nどう詫びる? (自由に書いてください — 媚びても、言い訳しても、堂々と構えても可)"
  else if kind == "liubang_xianyang_policy" then
    "咸陽宮、子嬰が玉璽を捧げた直後。 関中の民、貴族、降伏した秦の役人が\
あなた (劉邦) の宣言を待っている。 秦の苛法を全廃するか、\
温存するか、宝物・後宮をどう扱うか — あなた次第。\
\n\nどう宣言する? (自由に書いてください)"
  else ""

def aiResolveSituationEn(kind) :=
  if kind == "liubang_hongmen_apology" then
    "Hongmen. Xiang Yu's command tent. Fan Zeng's eyes burn; Xiang Zhuang has drawn his sword and is dancing.\
You (Liu Bang) must now apologise to Xiang Yu in person.\
A single sentence will decide your fate.\
\n\nHow do you apologise? (Write freely — flatter, make excuses, stand proud, anything)"
  else if kind == "liubang_xianyang_policy" then
    "The palace at Xianyang, immediately after Ziying offered the imperial seal.\
The people of Guanzhong, the nobility, and the surrendered Qin officials all wait for your (Liu Bang's) declaration.\
Will you abolish Qin's harsh laws? Preserve them? Plunder the treasures and harem?\
\n\nWhat do you declare? (Write freely)"
  else ""

-- Route to the next scene from an outcome bucket. Kept here so changing
-- where a fork lands is a one-line edit.
def aiResolveGotoGood(kind) :=
  if kind == "liubang_hongmen_apology" then "liubang_hongmen_escape_good"
  else if kind == "liubang_xianyang_policy" then "liubang_after_xianyang_good"
  else ""

def aiResolveGotoOk(kind) :=
  if kind == "liubang_hongmen_apology" then "liubang_hongmen_escape_ok"
  else if kind == "liubang_xianyang_policy" then "liubang_after_xianyang_ok"
  else ""

def aiResolveGotoBad(kind) :=
  if kind == "liubang_hongmen_apology" then "liubang_hongmen_died"
  else if kind == "liubang_xianyang_policy" then "liubang_after_xianyang_bad"
  else ""

def initResolveFor(kind) := Resolve {
  active: true, kind: kind,
  situationJa: aiResolveSituationJa(kind),
  situationEn: aiResolveSituationEn(kind),
  gotoGood: aiResolveGotoGood(kind),
  gotoOk: aiResolveGotoOk(kind),
  gotoBad: aiResolveGotoBad(kind),
  playerText: "", pending: false, lastError: "",
  resultOutcome: "", resultReasoning: ""
}

-- State
def initState := {
  phase: "title",
  lang: "ja",
  char: "",
  sceneId: "",
  beat: 0,
  stats: initStats,
  flags: {},
  battle: initBattle,
  mini: initMini,
  endingId: "",
  toast: "",
  llm: initLlm,
  resolve: initResolve
}

-- ── Helpers for state manipulation ──────────────────────────────────
def applyChoiceToStats(s, c) := Stats {
  hp: s.hp, maxHp: s.maxHp,
  bu: s.bu + c.dBu, zhi: s.zhi + c.dZhi,
  mei: s.mei + c.dMei, zheng: s.zheng + c.dZheng,
  karma: s.karma + c.dKarma,
  wife: s.wife + c.dWife, wifeFear: s.wifeFear + c.dWifeFear,
  trust: s.trust + c.dTrust, minXin: s.minXin + c.dMinXin,
  year: s.year
}

-- Step lookup
def stepAt(scene, n) :=
  if n < arrLen(scene) then arrGet(scene, n) else blankStep

-- ── Mini-game helpers ──────────────────────────────────────────────
-- Score 0..6 for face_read. 呂公 looks for "dragon face":
-- sharp eyes (2) + slight smile (1) + dignified (2). Exact = 6.
def faceReadScore(eyes, mouth, pose) :=
  let e := if eyes == 2 then 2 else if eyes == 1 then 1 else 0;
  let m := if mouth == 1 then 2 else if mouth == 2 then 1 else 0;
  let p := if pose == 2 then 2 else if pose == 1 then 1 else 0;
  e + m + p

-- jade_ring tunings: each round 2400ms, hit window 900..1500ms.
def ringRoundMs := 2400
def ringWindowStart := 900
def ringWindowEnd := 1500
def ringTotalRounds := 3

-- beishui scoring. Right pattern: card 1 → card 0 → card 2 = 9 pts.
-- (LeanJs match patterns don't support numeric literals — use if-chain.)
def bsCardScore(turn, card) :=
  if turn == 0 then (if card == 1 then 3 else if card == 0 then 1 else 0)
  else if turn == 1 then (if card == 0 then 3 else if card == 1 then 2 else 1)
  else if turn == 2 then (if card == 2 then 3 else if card == 0 then 1 else 0)
  else 0

def bsCardImpactHan(turn, card) :=
  if turn == 0 then (if card == 1 then 0 else if card == 0 then 20 else 50)
  else if turn == 1 then (if card == 0 then 5 else if card == 1 then 15 else 10)
  else if turn == 2 then (if card == 2 then 5 else if card == 0 then 25 else 60)
  else 20

def bsCardImpactZhao(turn, card) :=
  if turn == 0 then (if card == 1 then 40 else if card == 0 then 20 else 0)
  else if turn == 1 then (if card == 0 then 60 else if card == 1 then 40 else 45)
  else if turn == 2 then (if card == 2 then 100 else if card == 0 then 50 else 0)
  else 30

def bsLogForTurn(turn, card) :=
  if turn == 0 then
    (if card == 0 then "布陣: 高地に陣を敷く  (常識的)"
     else if card == 1 then "布陣: 背水に陣を敷く  (兵に退路無し、士気は極限へ)"
     else "布陣: 退却の構え  (戦わずして敗北濃厚)")
  else if turn == 1 then
    (if card == 0 then "戦法: 黙して陣を敷く (兵は震えるが死力を尽くす)"
     else if card == 1 then "戦法: 兵に布陣の意を説く (理解されるが意図が漏れる)"
     else "戦法: 奇兵を先に出す (本陣手薄)")
  else if turn == 2 then
    (if card == 0 then "決戦: 正面で死守 (五分五分)"
     else if card == 1 then "決戦: 後退して再編成 (時を稼ぐ)"
     else "決戦: 別動隊で趙本陣を奇襲 (赤旗を立てる)")
  else ""

def bsResolveTurn(m, card) := (
  let han := m.bsHanHp - bsCardImpactHan(m.bsTurn, card);
  let zhao := m.bsZhaoHp - bsCardImpactZhao(m.bsTurn, card);
  let pts := m.bsScore + bsCardScore(m.bsTurn, card);
  let logLine := bsLogForTurn(m.bsTurn, card);
  let nt := m.bsTurn + 1;
  let log1 := if m.bsTurn == 0 then logLine else m.bsLog1;
  let log2 := if m.bsTurn == 1 then logLine else m.bsLog2;
  let log3 := if m.bsTurn == 2 then logLine else m.bsLog3;
  Mini {
    kind: m.kind,
    faceEyes: m.faceEyes, faceMouth: m.faceMouth, facePose: m.facePose,
    faceShown: m.faceShown, faceScore: m.faceScore,
    ringNowMs: m.ringNowMs, ringRound: m.ringRound, ringHits: m.ringHits,
    ringRoundStartMs: m.ringRoundStartMs,
    ringClickedThisRound: m.ringClickedThisRound,
    ringFinished: m.ringFinished,
    bsTurn: nt, bsHanHp: maxI(0, han), bsZhaoHp: maxI(0, zhao),
    bsScore: pts, bsLog1: log1, bsLog2: log2, bsLog3: log3,
    bsFinished: nt >= 3
  })

-- Bucket mini score (0..max) to good/ok/bad scene id from cur step.
def miniBucket(score, maxScore, cur) := (
  let third := maxScore / 3;
  if score > maxScore - third then cur.miniGood
  else if score > third then cur.miniOk
  else cur.miniBad)

-- ── Update ──────────────────────────────────────────────────────────
def update(msg, state) :=
  match msg.tag with
  | "startSelect" => { phase: "select", lang: state.lang,
                       char: "", sceneId: "", beat: 0,
                       stats: state.stats, flags: state.flags,
                       battle: state.battle, endingId: "", toast: "" , mini: state.mini, llm: state.llm, resolve: state.resolve}
  | "sbSetup" => { phase: "sbSetup", lang: state.lang,
                       char: "", sceneId: "", beat: 0,
                       stats: state.stats, flags: state.flags,
                       battle: state.battle, endingId: "", toast: "" , mini: state.mini, llm: state.llm, resolve: state.resolve}
  | "sbStart" => sbStateWith(state, initWorldFor(msg.anchor, msg.mode))
  | "sbAdvance" => sbStep(state, sbTick(state.world))
  | "dramaChoice" =>
    (if state.phase == "sandbox" then sbStep(state, sbResolveDrama(state.world, msg.choice)) else state)
  | "expedition" =>
    (if state.phase == "sandbox" then sbStep(state, sbExpedition(state.world, msg.target)) else state)
  | "sbSpecial" =>
    (if state.phase == "sandbox" then sbStep(state, sbSpecialResolve(state.world)) else state)
  | "sbActionResult" => (
    if state.phase == "sandbox" then
      (let w := state.world;
       let mi := sbTopIdxOf(w.regions, "han", 0, -1, 0);
       let ei := sbTopEnemyIdx(w.regions, sbPlayerFaction(w.who), 0, -1, 0);
       let regions2 := if msg.win
         then sbAdj(w.regions, ei, 0 - msg.kills)
         else sbAdj(w.regions, mi, -10);
       let line := if msg.win
         then sconcat("🗡 出撃。敵 ", sconcat(jstr(msg.kills), " を斬り伏せ、前線を押し込んだ。名も無き働きが、確かに天下を動かす。"))
         else "🗡 出撃。深手を負って退いた。命あっての物種、手柄はまた次に。";
       sbStep(state, sbWorld(w.mode, sbNextYear(w.year, w.season),
         sbNextSeason(w.season), w.loc, regions2, arrPush(w.log, line), 0, w.who, w.court)))
    else state)
  | "battleResolve" =>
    (if state.phase == "sandbox" then sbStep(state, sbBattleResolve(state.world)) else state)
  | "gmSubmit" => (
    let w := state.world;
    sbStateWith(state,
      sbWorld(w.mode, w.year, w.season, w.loc, w.regions,
        arrPush(w.log, sconcat(sconcat("▶ ", sconcat(w.who, ": ")), msg.text)), 1, w.who, w.court)))
  | "gmResult" => (
    let w := state.world;
    let regions2 := sbApplyDeltas(w.regions, msg.deltas, 0);
    let w1 := sbWorld(w.mode, sbNextYear(w.year, w.season), sbNextSeason(w.season),
        w.loc, regions2, arrPush(w.log, msg.narration), 0, w.who, w.court);
    -- GM が構造化アクション(遠征/反乱/忠誠/兵糧)を返していれば適用。
    sbStep(state, sbApplyGmAction(w1, msg.action)))
  | "gmError" => (
    let w2 := sbTick(state.world);
    sbStep(state,
      sbWorld(w2.mode, w2.year, w2.season, w2.loc, w2.regions,
        arrPush(w2.log, "（AI 不通ゆえ、天下は独りでに動いた）"), 0, w2.who, w2.court)))
  | "toTitle" => { phase: "title", lang: state.lang,
                       char: "", sceneId: "", beat: 0,
                       stats: state.stats, flags: state.flags,
                       battle: state.battle, endingId: "", toast: "" , mini: state.mini, llm: state.llm, resolve: state.resolve}
  | "pickChar" => (
    let cid := msg.id;
    let sid := startSceneFor(cid);
    { phase: "scene", lang: state.lang,
      char: cid, sceneId: sid, beat: 0,
      stats: initStats, flags: {},
      battle: initBattle, endingId: "", toast: "" , mini: initMini, llm: initLlm, resolve: initResolve})
  | "setLang" =>
    { phase: state.phase, lang: msg.lang,
      char: state.char, sceneId: state.sceneId, beat: state.beat,
      stats: state.stats, flags: state.flags,
      battle: state.battle, endingId: state.endingId, toast: state.toast , mini: state.mini, llm: state.llm, resolve: state.resolve}
  | "advance" => (
    if state.phase != "scene" then state
    else
      let scene := sceneOf(state.sceneId);
      let cur := stepAt(scene, state.beat);
      if cur.ending != "" then state
      else if arrLen(cur.choices) > 0 then state
      else if cur.gotoScene != "" then
        { phase: "scene", lang: state.lang,
          char: state.char, sceneId: cur.gotoScene, beat: 0,
          stats: state.stats, flags: state.flags,
          battle: state.battle, endingId: "", toast: state.toast , mini: state.mini, llm: state.llm, resolve: state.resolve}
      else
        let nb := state.beat + 1;
        let nxt := stepAt(scene, nb);
        if nxt.ending != "" then (
          let _ := lsRecordEnding(nxt.ending);
          { phase: "ending", lang: state.lang,
            char: state.char, sceneId: state.sceneId, beat: nb,
            stats: state.stats, flags: state.flags,
            battle: state.battle, endingId: nxt.ending, toast: state.toast , mini: state.mini, llm: state.llm, resolve: state.resolve})
        else if nxt.gotoScene != "" then
          { phase: "scene", lang: state.lang,
            char: state.char, sceneId: nxt.gotoScene, beat: 0,
            stats: state.stats, flags: state.flags,
            battle: state.battle, endingId: "", toast: state.toast , mini: state.mini, llm: state.llm, resolve: state.resolve}
        else if nxt.miniKind != "" then
          { phase: "minigame", lang: state.lang,
            char: state.char, sceneId: state.sceneId, beat: nb,
            stats: state.stats, flags: state.flags,
            battle: state.battle, endingId: state.endingId, toast: state.toast,
            mini: initMiniFor(nxt.miniKind) , llm: state.llm, resolve: state.resolve}
        else if nxt.npcChat != "" then
          { phase: "llm_chat", lang: state.lang,
            char: state.char, sceneId: state.sceneId, beat: nb,
            stats: state.stats, flags: state.flags,
            battle: state.battle, endingId: state.endingId, toast: state.toast,
            mini: state.mini, llm: initLlmFor(nxt.npcChat, nxt.gotoScene), resolve: state.resolve }
        else if nxt.aiResolveKind != "" then
          { phase: "ai_resolve", lang: state.lang,
            char: state.char, sceneId: state.sceneId, beat: nb,
            stats: state.stats, flags: state.flags,
            battle: state.battle, endingId: state.endingId, toast: state.toast,
            mini: state.mini, llm: state.llm,
            resolve: initResolveFor(nxt.aiResolveKind) }
        else
          { phase: state.phase, lang: state.lang,
            char: state.char, sceneId: state.sceneId, beat: nb,
            stats: state.stats, flags: state.flags,
            battle: state.battle, endingId: state.endingId, toast: state.toast , mini: state.mini, llm: state.llm, resolve: state.resolve})
  | "choose" => (
    let scene := sceneOf(state.sceneId);
    let cur := stepAt(scene, state.beat);
    let cs := cur.choices;
    let idx := msg.idx;
    if idx < arrLen(cs) then
      let c := arrGet(cs, idx);
      let newStats := applyChoiceToStats(state.stats, c);
      if c.gotoScene != "" then
        { phase: "scene", lang: state.lang,
          char: state.char, sceneId: c.gotoScene, beat: 0,
          stats: newStats, flags: state.flags,
          battle: state.battle, endingId: "", toast: c.setFlag , mini: state.mini, llm: state.llm, resolve: state.resolve}
      else
        { phase: state.phase, lang: state.lang,
          char: state.char, sceneId: state.sceneId, beat: state.beat + 1,
          stats: newStats, flags: state.flags,
          battle: state.battle, endingId: state.endingId, toast: c.setFlag , mini: state.mini, llm: state.llm, resolve: state.resolve}
    else state)
  -- Mini: face_read ─────────────────────────
  | "miniFace" => (
    let m := state.mini;
    let part := msg.part;
    let v := msg.value;
    let newM := Mini {
      kind: m.kind,
      faceEyes: if part == "eyes" then v else m.faceEyes,
      faceMouth: if part == "mouth" then v else m.faceMouth,
      facePose: if part == "pose" then v else m.facePose,
      faceShown: m.faceShown, faceScore: m.faceScore,
      ringNowMs: m.ringNowMs, ringRound: m.ringRound, ringHits: m.ringHits,
      ringRoundStartMs: m.ringRoundStartMs,
      ringClickedThisRound: m.ringClickedThisRound,
      ringFinished: m.ringFinished,
      bsTurn: m.bsTurn, bsHanHp: m.bsHanHp, bsZhaoHp: m.bsZhaoHp,
      bsScore: m.bsScore, bsLog1: m.bsLog1, bsLog2: m.bsLog2, bsLog3: m.bsLog3,
      bsFinished: m.bsFinished
    };
    { phase: state.phase, lang: state.lang,
      char: state.char, sceneId: state.sceneId, beat: state.beat,
      stats: state.stats, flags: state.flags, battle: state.battle,
      endingId: state.endingId, toast: state.toast, mini: newM , llm: state.llm, resolve: state.resolve})
  | "miniFaceShow" => (
    let m := state.mini;
    let sc := faceReadScore(m.faceEyes, m.faceMouth, m.facePose);
    let newM := Mini {
      kind: m.kind,
      faceEyes: m.faceEyes, faceMouth: m.faceMouth, facePose: m.facePose,
      faceShown: true, faceScore: sc,
      ringNowMs: m.ringNowMs, ringRound: m.ringRound, ringHits: m.ringHits,
      ringRoundStartMs: m.ringRoundStartMs,
      ringClickedThisRound: m.ringClickedThisRound,
      ringFinished: m.ringFinished,
      bsTurn: m.bsTurn, bsHanHp: m.bsHanHp, bsZhaoHp: m.bsZhaoHp,
      bsScore: m.bsScore, bsLog1: m.bsLog1, bsLog2: m.bsLog2, bsLog3: m.bsLog3,
      bsFinished: m.bsFinished
    };
    { phase: state.phase, lang: state.lang,
      char: state.char, sceneId: state.sceneId, beat: state.beat,
      stats: state.stats, flags: state.flags, battle: state.battle,
      endingId: state.endingId, toast: state.toast, mini: newM , llm: state.llm, resolve: state.resolve})
  | "miniFaceDone" => (
    let scene := sceneOf(state.sceneId);
    let cur := stepAt(scene, state.beat);
    let nextSceneId := miniBucket(state.mini.faceScore, 6, cur);
    { phase: "scene", lang: state.lang,
      char: state.char, sceneId: nextSceneId, beat: 0,
      stats: state.stats, flags: state.flags, battle: state.battle,
      endingId: "", toast: "mini:face", mini: initMini , llm: state.llm, resolve: state.resolve})
  -- Mini: jade_ring ─────────────────────────
  | "miniRingTick" => (
    let m := state.mini;
    if m.ringFinished then state
    else
      let now := msg.now;
      let elapsed := now - m.ringRoundStartMs;
      if elapsed >= ringRoundMs then
        let nextRound := m.ringRound + 1;
        let fin := nextRound >= ringTotalRounds;
        let newM := Mini {
          kind: m.kind,
          faceEyes: m.faceEyes, faceMouth: m.faceMouth, facePose: m.facePose,
          faceShown: m.faceShown, faceScore: m.faceScore,
          ringNowMs: now, ringRound: nextRound, ringHits: m.ringHits,
          ringRoundStartMs: now,
          ringClickedThisRound: false,
          ringFinished: fin,
          bsTurn: m.bsTurn, bsHanHp: m.bsHanHp, bsZhaoHp: m.bsZhaoHp,
          bsScore: m.bsScore, bsLog1: m.bsLog1, bsLog2: m.bsLog2, bsLog3: m.bsLog3,
          bsFinished: m.bsFinished
        };
        { phase: state.phase, lang: state.lang,
          char: state.char, sceneId: state.sceneId, beat: state.beat,
          stats: state.stats, flags: state.flags, battle: state.battle,
          endingId: state.endingId, toast: state.toast, mini: newM , llm: state.llm, resolve: state.resolve}
      else
        let newM := Mini {
          kind: m.kind,
          faceEyes: m.faceEyes, faceMouth: m.faceMouth, facePose: m.facePose,
          faceShown: m.faceShown, faceScore: m.faceScore,
          ringNowMs: now, ringRound: m.ringRound, ringHits: m.ringHits,
          ringRoundStartMs: m.ringRoundStartMs,
          ringClickedThisRound: m.ringClickedThisRound,
          ringFinished: m.ringFinished,
          bsTurn: m.bsTurn, bsHanHp: m.bsHanHp, bsZhaoHp: m.bsZhaoHp,
          bsScore: m.bsScore, bsLog1: m.bsLog1, bsLog2: m.bsLog2, bsLog3: m.bsLog3,
          bsFinished: m.bsFinished
        };
        { phase: state.phase, lang: state.lang,
          char: state.char, sceneId: state.sceneId, beat: state.beat,
          stats: state.stats, flags: state.flags, battle: state.battle,
          endingId: state.endingId, toast: state.toast, mini: newM , llm: state.llm, resolve: state.resolve})
  | "miniRingClick" => (
    let m := state.mini;
    if m.ringFinished then state
    else if m.ringClickedThisRound then state
    else
      let elapsed := m.ringNowMs - m.ringRoundStartMs;
      let hit := elapsed >= ringWindowStart && elapsed < ringWindowEnd;
      let newHits := if hit then m.ringHits + 1 else m.ringHits;
      let newM := Mini {
        kind: m.kind,
        faceEyes: m.faceEyes, faceMouth: m.faceMouth, facePose: m.facePose,
        faceShown: m.faceShown, faceScore: m.faceScore,
        ringNowMs: m.ringNowMs, ringRound: m.ringRound, ringHits: newHits,
        ringRoundStartMs: m.ringRoundStartMs,
        ringClickedThisRound: true,
        ringFinished: m.ringFinished,
        bsTurn: m.bsTurn, bsHanHp: m.bsHanHp, bsZhaoHp: m.bsZhaoHp,
        bsScore: m.bsScore, bsLog1: m.bsLog1, bsLog2: m.bsLog2, bsLog3: m.bsLog3,
        bsFinished: m.bsFinished
      };
      { phase: state.phase, lang: state.lang,
        char: state.char, sceneId: state.sceneId, beat: state.beat,
        stats: state.stats, flags: state.flags, battle: state.battle,
        endingId: state.endingId, toast: state.toast, mini: newM , llm: state.llm, resolve: state.resolve})
  | "miniRingDone" => (
    let scene := sceneOf(state.sceneId);
    let cur := stepAt(scene, state.beat);
    let nextSceneId := miniBucket(state.mini.ringHits, 3, cur);
    { phase: "scene", lang: state.lang,
      char: state.char, sceneId: nextSceneId, beat: 0,
      stats: state.stats, flags: state.flags, battle: state.battle,
      endingId: "", toast: "mini:ring", mini: initMini , llm: state.llm, resolve: state.resolve})
  -- Mini: beishui ─────────────────────────
  | "miniBsCard" => (
    let m := state.mini;
    if m.bsFinished then state
    else
      let newM := bsResolveTurn(m, msg.card);
      { phase: state.phase, lang: state.lang,
        char: state.char, sceneId: state.sceneId, beat: state.beat,
        stats: state.stats, flags: state.flags, battle: state.battle,
        endingId: state.endingId, toast: state.toast, mini: newM , llm: state.llm, resolve: state.resolve})
  | "miniBsDone" => (
    let scene := sceneOf(state.sceneId);
    let cur := stepAt(scene, state.beat);
    let nextSceneId := miniBucket(state.mini.bsScore, 9, cur);
    { phase: "scene", lang: state.lang,
      char: state.char, sceneId: nextSceneId, beat: 0,
      stats: state.stats, flags: state.flags, battle: state.battle,
      endingId: "", toast: "mini:bs", mini: initMini , llm: state.llm, resolve: state.resolve})
  -- Mini: LLM NPC chat ─────────────────────
  | "llmSendUser" => (
    let m := state.llm;
    let entry := { role: "user", text: msg.text };
    let newH := arrPush(m.history, entry);
    let newL := Llm {
      active: m.active, npcId: m.npcId,
      npcName: m.npcName, npcColor: m.npcColor,
      history: newH, pending: true, sceneAfter: m.sceneAfter,
      lastError: ""
    };
    { phase: state.phase, lang: state.lang,
      char: state.char, sceneId: state.sceneId, beat: state.beat,
      stats: state.stats, flags: state.flags, battle: state.battle,
      endingId: state.endingId, toast: state.toast, mini: state.mini,
      llm: newL, resolve: state.resolve })
  | "llmReply" => (
    let m := state.llm;
    let entry := { role: "assistant", text: msg.text };
    let newH := arrPush(m.history, entry);
    let newL := Llm {
      active: m.active, npcId: m.npcId,
      npcName: m.npcName, npcColor: m.npcColor,
      history: newH, pending: false, sceneAfter: m.sceneAfter,
      lastError: ""
    };
    { phase: state.phase, lang: state.lang,
      char: state.char, sceneId: state.sceneId, beat: state.beat,
      stats: state.stats, flags: state.flags, battle: state.battle,
      endingId: state.endingId, toast: state.toast, mini: state.mini,
      llm: newL, resolve: state.resolve })
  | "llmError" => (
    let m := state.llm;
    let newL := Llm {
      active: m.active, npcId: m.npcId,
      npcName: m.npcName, npcColor: m.npcColor,
      history: m.history, pending: false, sceneAfter: m.sceneAfter,
      lastError: msg.text
    };
    { phase: state.phase, lang: state.lang,
      char: state.char, sceneId: state.sceneId, beat: state.beat,
      stats: state.stats, flags: state.flags, battle: state.battle,
      endingId: state.endingId, toast: state.toast, mini: state.mini,
      llm: newL, resolve: state.resolve })
  | "llmEnd" => (
    let after := state.llm.sceneAfter;
    { phase: "scene", lang: state.lang,
      char: state.char, sceneId: after, beat: 0,
      stats: state.stats, flags: state.flags, battle: state.battle,
      endingId: "", toast: "llm:end", mini: state.mini, llm: initLlm, resolve: initResolve })
  -- TRPG aiResolve handlers ───────────────────
  | "resolveSubmit" => (
    let r := state.resolve;
    let newR := Resolve {
      active: r.active, kind: r.kind,
      situationJa: r.situationJa, situationEn: r.situationEn,
      gotoGood: r.gotoGood, gotoOk: r.gotoOk, gotoBad: r.gotoBad,
      playerText: msg.text, pending: true, lastError: "",
      resultOutcome: "", resultReasoning: ""
    };
    { phase: state.phase, lang: state.lang,
      char: state.char, sceneId: state.sceneId, beat: state.beat,
      stats: state.stats, flags: state.flags, battle: state.battle,
      endingId: state.endingId, toast: state.toast, mini: state.mini,
      llm: state.llm, resolve: newR })
  | "resolveResult" => (
    let r := state.resolve;
    let newR := Resolve {
      active: r.active, kind: r.kind,
      situationJa: r.situationJa, situationEn: r.situationEn,
      gotoGood: r.gotoGood, gotoOk: r.gotoOk, gotoBad: r.gotoBad,
      playerText: r.playerText, pending: false, lastError: "",
      resultOutcome: msg.outcome, resultReasoning: msg.reasoning
    };
    { phase: state.phase, lang: state.lang,
      char: state.char, sceneId: state.sceneId, beat: state.beat,
      stats: state.stats, flags: state.flags, battle: state.battle,
      endingId: state.endingId, toast: state.toast, mini: state.mini,
      llm: state.llm, resolve: newR })
  | "resolveError" => (
    let r := state.resolve;
    let newR := Resolve {
      active: r.active, kind: r.kind,
      situationJa: r.situationJa, situationEn: r.situationEn,
      gotoGood: r.gotoGood, gotoOk: r.gotoOk, gotoBad: r.gotoBad,
      playerText: r.playerText, pending: false, lastError: msg.text,
      resultOutcome: "", resultReasoning: ""
    };
    { phase: state.phase, lang: state.lang,
      char: state.char, sceneId: state.sceneId, beat: state.beat,
      stats: state.stats, flags: state.flags, battle: state.battle,
      endingId: state.endingId, toast: state.toast, mini: state.mini,
      llm: state.llm, resolve: newR })
  | "resolveAdvance" => (
    let r := state.resolve;
    let next := if r.resultOutcome == "good" then r.gotoGood
                else if r.resultOutcome == "ok" then r.gotoOk
                else if r.resultOutcome == "bad" then r.gotoBad
                else "";
    if next == "" then state
    else
      { phase: "scene", lang: state.lang,
        char: state.char, sceneId: next, beat: 0,
        stats: state.stats, flags: state.flags, battle: state.battle,
        endingId: "", toast: sjoin(["resolve:", r.resultOutcome]),
        mini: state.mini, llm: state.llm, resolve: initResolve })
  -- Save / load handlers — direct localStorage via externs.
  -- (LeanJs functions are pure in spirit; the externs do the IO.)
  | "toggleSaveMenu" => (
    let cur := state.flags._saveMenuOpen == true;
    let newFlags := { _saveMenuOpen: (! cur) };
    { phase: state.phase, lang: state.lang,
      char: state.char, sceneId: state.sceneId, beat: state.beat,
      stats: state.stats, flags: newFlags, battle: state.battle,
      endingId: state.endingId, toast: state.toast, mini: state.mini, llm: state.llm, resolve: state.resolve })
  | "saveSlot1" => (
    let _ := lsSave(lsKeySlot(1), state);
    state )
  | "saveSlot2" => (
    let _ := lsSave(lsKeySlot(2), state);
    state )
  | "saveSlot3" => (
    let _ := lsSave(lsKeySlot(3), state);
    state )
  | "loadSlot1" => (
    let s := lsLoad(lsKeySlot(1));
    if s == null then state else s )
  | "loadSlot2" => (
    let s := lsLoad(lsKeySlot(2));
    if s == null then state else s )
  | "loadSlot3" => (
    let s := lsLoad(lsKeySlot(3));
    if s == null then state else s )
  | "loadCheckpoint" => (
    let s := lsLoad(lsKeyCheckpoint);
    if s == null then state else s )
  | "restart" => initState
  | "reset" => initState
  | "openGallery" => (
    { phase: "gallery", lang: state.lang,
      char: state.char, sceneId: "", beat: 0,
      stats: state.stats, flags: state.flags, battle: state.battle,
      endingId: "", toast: "", mini: state.mini, llm: state.llm, resolve: state.resolve })
  | "closeGallery" => initState
  -- Test mode: jump to any scene from the title (URL ?scene=…)
  | "jumpToScene" => (
    let cid := msg.char;
    { phase: "scene", lang: state.lang,
      char: cid, sceneId: msg.sceneId, beat: 0,
      stats: initStats, flags: {}, battle: initBattle,
      endingId: "", toast: "", mini: initMini, llm: initLlm, resolve: initResolve })
  | "backToSelect" => { phase: "select", lang: state.lang,
                        char: "", sceneId: "", beat: 0,
                        stats: initStats, flags: {},
                        battle: initBattle, endingId: "", toast: "" , mini: state.mini, llm: state.llm, resolve: state.resolve}
  | "toggleMute" => (
    let _ := audioToggleMute();
    state )
  | _ => state

-- ── View ────────────────────────────────────────────────────────────
-- HUD rendered on every phase except title.

-- Produce a single-quoted JSON literal suitable for a `data-msg` HTML
-- attribute. We can't write `"` inside LeanJs string literals (parser
-- has no escape support), so JSON construction goes through `jstr`.
def msgAttr(o) := sjoin(["'", jstr(o), "'"])

-- ── Button kit ─────────────────────────────────────────────────────
-- Every interactive control in the game goes through one of three
-- helpers below. The `kind` string maps onto `.btn-<kind>` in page.html
-- and on the JS side it drives the per-kind SFX table. Adding a new
-- button means picking a kind — CSS + click + SFX are then all wired
-- automatically; we never hand-roll a fresh class name + sfx tag pair.
--
-- Kinds in use:
--   primary  — large CTA (START, タイトルへ戻る, 続ける ▶)
--   icon     — compact icon / menu-bar button (🔊 💾 JA EN 選択へ)
--   menu     — save-menu list item
--   choice   — in-scene scenario choice (text + optional hint)
--   face     — face-reader 3-up grid pick
--   jade     — single big highlighted action button (玉玦を上げる)
--   card     — multi-section clickable card (bs-card, char-card)
--
-- Use `buttonMod` for `.active` etc. state, `buttonHtml` when the
-- label needs nested markup (already escaped by the caller).

def button(kind, msg, label) :=
  sjoin([
    "<button class='btn btn-", kind, "' data-msg=", msgAttr(msg), ">",
    hesc(label), "</button>"
  ])

def buttonMod(kind, mod, msg, label) :=
  sjoin([
    "<button class='btn btn-", kind, mod, "' data-msg=", msgAttr(msg), ">",
    hesc(label), "</button>"
  ])

def buttonHtml(kind, msg, htmlBody) :=
  sjoin([
    "<button class='btn btn-", kind, "' data-msg=", msgAttr(msg), ">",
    htmlBody, "</button>"
  ])

-- ── Panel kit ──────────────────────────────────────────────────────
-- Bordered container with optional title. Same kind-driven idea as the
-- button kit: `panel("mini", "顔相鑑定", body)` emits a panel with the
-- mini-game styling. Empty title skips the <h2>.
def panel(kind, title, body) :=
  let head := if title == "" then ""
              else sjoin(["<h2>", hesc(title), "</h2>"]);
  sjoin([
    "<div class='panel panel-", kind, "'>",
    head, body, "</div>"
  ])

def panelMod(kind, mod, title, body) :=
  let head := if title == "" then ""
              else sjoin(["<h2>", hesc(title), "</h2>"]);
  sjoin([
    "<div class='panel panel-", kind, " ", mod, "'>",
    head, body, "</div>"
  ])

-- ── Portrait helper ────────────────────────────────────────────────
-- Image with a gradient caption overlay at the bottom. Used by the
-- character-select card and (eventually) any sprite that wants the
-- same treatment.
def portrait(src, alt, caption) :=
  sjoin([
    "<div class='portrait'>",
    "<img src='", src, "' alt='", hesc(alt), "' loading='lazy'>",
    "<div class='portrait-name'>", hesc(caption), "</div>",
    "</div>"
  ])

-- ── hpBar / progressBar ────────────────────────────────────────────
-- Horizontal gauge: label · fill · numeric. Kinds:
--   hp     — red-to-orange gradient, HP-style (beishui)
--   ring   — dark bar with a green target window + moving cursor
--            (jade_ring's timing bar; the extras are optional overlays)
-- Both share the same base .gauge / .gauge-fill markup so a new gauge
-- variant is just a CSS rule + a new kind value.

def hpBar(kind, label, cur, max) :=
  let pct := if max == 0 then 0 else cur * 100 / max;
  sjoin([
    "<div class='gauge gauge-", kind, "'>",
    "<span class='gauge-label'>", hesc(label), "</span>",
    "<div class='gauge-track'><div class='gauge-fill' style='width:",
      jstr(pct), "%'></div></div>",
    "<span class='gauge-num'>", jstr(cur), "/", jstr(max), "</span>",
    "</div>"
  ])

-- Ring-style progress bar with a hit window and a moving cursor.
-- Reuses .gauge-track underneath; adds two absolutely-positioned
-- children for the window band and the cursor line.
def ringBar(progressPct, windowStartPct, windowWidthPct) :=
  sjoin([
    "<div class='gauge gauge-ring'>",
    "<div class='gauge-track'>",
    "<div class='ring-window' style='left:", jstr(windowStartPct),
      "%; width:", jstr(windowWidthPct), "%'></div>",
    "<div class='ring-cursor' style='left:", jstr(progressPct), "%'></div>",
    "</div></div>"
  ])

-- ── btnRow — inline flex row of buttons/controls ───────────────────
-- Wraps a pre-built HTML body of controls in a labelled flex row.
-- Same shape as the current facerow / .lang / .save-pop containers,
-- with one kind system so the row style is consistent.
--
-- Kinds:
--   face  — small flex row with a leading label column ("目つき:"),
--           child buttons expand to fill (used in 顔相鑑定)
--   inline— header-bar inline row (JA/EN language toggle)
--   menu  — vertical stacked menu (save-pop, drops to `display: flex`
--           in column direction)

def btnRow(kind, label, buttonsHtml) :=
  let labelSpan := if label == "" then ""
                   else sjoin(["<span class='btn-row-label'>", hesc(label), "</span>"]);
  sjoin([
    "<div class='btn-row btn-row-", kind, "'>",
    labelSpan, buttonsHtml,
    "</div>"
  ])

-- ── dialogue — the speaker + say + think trio ──────────────────────
-- All VN beats need this triple. Empty speaker or think auto-skip
-- so the caller doesn't have to conditional it. `hint` is the
-- pulsing "▼ space / click" bottom-right hint the dialogue box has
-- traditionally rendered — pass "" to omit.

def dialogue(speaker, say, think, hint) :=
  let speakerHtml := if speaker == "" then ""
                     else sjoin(["<div class='dialogue-speaker'>", hesc(speaker), "</div>"]);
  let thinkHtml := if think == "" then ""
                   else sjoin(["<div class='dialogue-inner'>", hesc(think), "</div>"]);
  let hintHtml := if hint == "" then ""
                  else sjoin(["<div class='advance-hint'>", hesc(hint), "</div>"]);
  sjoin([
    speakerHtml,
    "<div class='dialogue-line'>", hesc(say), "</div>",
    thinkHtml, hintHtml
  ])

-- ── Missing-asset marker ───────────────────────────────────────────
-- Use when a character / background is referenced in the script but
-- no image exists yet. Renders a loud magenta placeholder so it can't
-- be ignored in-game, and the literal string "MISSING_ASSET:" makes
-- the call site grep-discoverable from anywhere in the tree.
--
-- The server's asset audit (Serve.lean) walks the compiled JS for
-- this marker and writes the full list to examples/ChuHan/MISSING_ASSETS.txt
-- at boot — so the canonical TODO list is generated, not hand-kept.
def missingAsset(name) :=
  sjoin([
    "<div class='missing-asset' data-name='", hesc(name),
    "' title='MISSING_ASSET: ", hesc(name), "'>?",
    hesc(name), "</div>"
  ])

def renderLang(state) :=
  let ja := if state.lang == "ja" then " active" else "";
  let en := if state.lang == "en" then " active" else "";
  btnRow("inline", "", sjoin([
    buttonMod("icon", ja, {tag: "setLang", lang: "ja"}, "JA"),
    buttonMod("icon", en, {tag: "setLang", lang: "en"}, "EN")
  ]))

-- Render the save/load drop-down. The slot labels read live from
-- localStorage on each render so they always reflect the latest
-- saves (no manual "refresh" needed).
def renderSaveMenuItem(action, label) :=
  button("menu", {tag: action}, label)

def renderSaveMenu(state) :=
  let open := state.flags._saveMenuOpen == true;
  let openClass := if open then "save-menu open" else "save-menu";
  -- Slot previews come from the server (via runtime.js's cache); the
  -- checkpoint stays local (autosave is client-side).
  let s1 := serverSlotLabel(1);
  let s2 := serverSlotLabel(2);
  let s3 := serverSlotLabel(3);
  let cp := describeState(lsLoad(lsKeyCheckpoint));
  sjoin([
    "<div class='", openClass, "'>",
    button("icon", {tag: "toggleSaveMenu"}, "💾"),
    "<div class='save-pop'>",
    renderSaveMenuItem("saveSlot1", "Slot 1 へ保存"),
    renderSaveMenuItem("saveSlot2", "Slot 2 へ保存"),
    renderSaveMenuItem("saveSlot3", "Slot 3 へ保存"),
    "<hr>",
    renderSaveMenuItem("loadSlot1", sjoin(["Slot 1 — ", s1])),
    renderSaveMenuItem("loadSlot2", sjoin(["Slot 2 — ", s2])),
    renderSaveMenuItem("loadSlot3", sjoin(["Slot 3 — ", s3])),
    "<hr>",
    renderSaveMenuItem("loadCheckpoint", sjoin(["↩ チェックポイント: ", cp])),
    renderSaveMenuItem("restart", "⟲ 最初からやり直す"),
    "<hr>",
    "<div class='save-code'>セーブコード: <b>", getSaveCodeStr(), "</b>",
    "<div class='save-code-hint'>別端末で下に入力すると同じセーブを復元できます</div>",
    "<input id='saveCodeInput' class='save-code-input' placeholder='コードを入力' />",
    button("menu", {tag: "applySaveCode"}, "このコードで復元"),
    "</div>",
    "</div></div>"
  ])

def renderHud(state) :=
  let s := state.stats;
  let charName := match state.char with
    | "liubang"    => "劉邦"
    | "xiangyu"    => "項羽"
    | "hanxin"     => "韓信"
    | "zhangliang" => "張良"
    | "xiaohe"     => "蕭何"
    | "fanzeng"    => "范増"
    | _ => "";
  sjoin([
    "<div class='hud'><span class='who'>", hesc(charName),
    "</span><span class='stat'>武<b>", jstr(s.bu),
    "</b></span><span class='stat'>智<b>", jstr(s.zhi),
    "</b></span><span class='stat'>魅<b>", jstr(s.mei),
    "</b></span><span class='stat'>政<b>", jstr(s.zheng),
    "</b></span><span class='stat'>嫁<b>", jstr(s.wife),
    "</b></span><span class='yr'>BCE ", jstr(0 - s.year),
    "</span>", renderLang(state),
    renderSaveMenu(state),
    button("icon", {tag: "toggleMute"}, (if audioIsMuted() == 1 then "🔇" else "🔊")),
    button("icon", {tag: "backToSelect"}, "選択へ"),
    "</div>"
  ])

-- All recorded endings with their human titles. The gallery and
-- the title-screen progress counter both read from this list.
def allEndingIds := [
  "act1_clear", "honest_anonymous", "cold_alone",
  "xiangyu_act1_clear", "phase2_placeholder",
  "hanxin_act1_clear", "hanxin_pride_dead",
  "zhangliang_act1_clear", "zhangliang_obscure",
  "xiaohe_act1_clear", "fanzeng_act1_clear",
  "face_read_failed",
  "liubang_act2_clear", "xiangyu_act2_clear", "hanxin_act2_clear",
  "zhangliang_act2_clear", "xiaohe_act2_clear", "fanzeng_died_in_grief",
  "liubang_died_hongmen", "liubang_withered", "liubang_threeway", "liubang_honggou_kept",
  "xiangyu_julu_failed", "xiangyu_killed_liu",
  "hanxin_xizheng_legend", "hanxin_beishui_lost",
  "xiaohe_looter", "xiaohe_purity_death",
  "fanzeng_jade_diverged",
  "xiangyu_wujiang", "xiangyu_crossed_recluse",
  "liubang_died_emperor",
  "hanxin_death_changle", "zhangliang_immortal_path", "xiaohe_died_chancellor"
]

-- Title screen
def countAchievedLoop(allObj, ids, i, acc) :=
  if i < arrLen(ids) then
    let next := if hasKey(allObj, arrGet(ids, i)) == 1 then acc + 1 else acc;
    countAchievedLoop(allObj, ids, i + 1, next)
  else acc

def galleryProgress :=
  let allRaw := lsLoad("chuhan-endings");
  let allObj := if allRaw == null then {} else allRaw;
  let total := arrLen(allEndingIds);
  let achieved := countAchievedLoop(allObj, allEndingIds, 0, 0);
  sjoin(["達成 END: ", jstr(achieved), " / ", jstr(total)])

def viewTitle(state) :=
  sjoin([
    "<div class='title-bg'><h1>楚漢恋歌</h1><div class='sub'>CHU·HAN LOVE SONG</div>",
    button("primary", {tag: "startSelect"}, "START"),
    button("primary", {tag: "sbSetup"}, "群雄サンドボックス β"),
    button("primary", {tag: "openGallery"}, "END ギャラリー"),
    "<div class='sub' style='font-size:11px;color:#666;margin-top:60px'>",
    "六つの生、六つの死、六つの恋。<br>BCE 209 ─ 195. Six lives. Six loves. Six deaths.<br><br>",
    galleryProgress,
    "</div></div>"
  ])

-- Character select grid
def renderCharCard(state, c) :=
  let mod := if state.char == c.id then " active" else "";
  let nm := if state.lang == "en" then c.nameEn else c.nameJa;
  let ep := if state.lang == "en" then c.epithetEn else c.epithetJa;
  let desc := if state.lang == "en" then c.descEn else c.descJa;
  let body := sjoin([
    portrait(sjoin(["/assets/char_", c.id, ".png"]), nm, nm),
    "<h3>", hesc(nm), "</h3>",
    "<div class='epithet'>", hesc(ep), "</div>",
    "<div class='desc'>", hesc(desc), "</div>",
    "<div class='difficulty'>難易度: ", hesc(c.difficulty), "</div>"
  ]);
  buttonHtml(sconcat("char", mod), {tag: "pickChar", id: c.id}, body)

def charLoop(state, cs, i, acc) :=
  if i < arrLen(cs) then
    charLoop(state, cs, i + 1,
      sconcat(acc, renderCharCard(state, arrGet(cs, i))))
  else acc

def viewSelect(state) :=
  let title := if state.lang == "en" then "Choose your fate" else "主人公を選べ";
  sjoin([
    "<div class='select-bg'>", renderHud(state),
    "<h2>", hesc(title), "</h2><div class='roster'>",
    charLoop(state, chars, 0, ""),
    "</div></div>"
  ])

-- Scene (dialogue) render
-- Map a Japanese sprite name to its photo-realistic asset path.
-- Returns "" if no portrait exists (e.g. unnamed extras like 「部下」).
def spriteAssetForName(name) :=
  if name == "劉邦" then "/assets/char_liubang.png"
  else if name == "項羽" then "/assets/char_xiangyu.png"
  else if name == "韓信" then "/assets/char_hanxin.png"
  else if name == "張良" then "/assets/char_zhangliang.png"
  else if name == "蕭何" then "/assets/char_xiaohe.png"
  else if name == "范増" then "/assets/char_fanzeng.png"
  else if name == "項伯" then "/assets/char_xiangbo.png"
  else if name == "蒯通" then "/assets/char_kuaitong.png"
  else if name == "黄石公" then "/assets/char_huangshi.png"
  else if name == "呂公" then "/assets/char_luwen.png"
  else if name == "呂雉" then "/assets/wife_luzhi.png"
  else if name == "虞姫" then "/assets/wife_yuji.png"
  else if name == "漂雲" then "/assets/wife_piaoyun.png"
  else if name == "黒綺" then "/assets/wife_kokuki.png"
  else if name == "妙容" then "/assets/wife_miaorong.png"
  else if name == "子嬰" then "/assets/char_ziying.png"
  else ""

def renderSprite(name, color, dim) :=
  let dimC := if dim then " dim" else "";
  let asset := spriteAssetForName(name);
  if asset == "" then
    -- Unknown name (extra / narrator placeholder) → coloured block.
    sjoin([
      "<div class='sprite", dimC,
      "' style='background:linear-gradient(180deg,", color,
      " 0%, ", color, " 60%, rgba(0,0,0,0.85) 100%)'>",
      hesc(name),
      "</div>"
    ])
  else
    -- 404s get swapped to .missing-asset by a centralised handler in
    -- page.html (stage-level `error` event capture). The asset audit
    -- in Serve.lean lists them at server boot too.
    sjoin([
      "<div class='sprite", dimC, "' style='background:none'>",
      "<img class='sprite-img' src='", asset, "' alt='", hesc(name), "'>",
      "<div class='sprite-name'>", hesc(name), "</div>",
      "</div>"
    ])

def renderSprites(step) := (
  let s1id := step.spriteId;
  let s2id := step.spriteId2;
  let focus := step.spriteFocus;
  if s1id == "" then ""
  else if s2id == "" then
    sjoin(["<div class='sprite-row'>", renderSprite(step.spriteName, step.spriteColor, false), "</div>"])
  else
    let dim1 := focus == 2;
    let dim2 := focus == 1;
    sjoin([
      "<div class='sprite-row'>",
      renderSprite(step.spriteName, step.spriteColor, dim1),
      renderSprite(step.spriteName2, step.spriteColor2, dim2),
      "</div>"
    ]))

def renderDialogueBox(state, step) :=
  let say := if state.lang == "en" then (if step.sayEn == "" then step.sayJa else step.sayEn) else step.sayJa;
  let think := if state.lang == "en" then (if step.thinkEn == "" then step.thinkJa else step.thinkEn) else step.thinkJa;
  let speaker := if state.lang == "en" then (if step.speakerEn == "" then step.speakerJa else step.speakerEn) else step.speakerJa;
  panel("dialogue", "", dialogue(speaker, say, think, "▼ space / click"))

def renderChoice(state, c, i) :=
  let label := if state.lang == "en" then (if c.labelEn == "" then c.labelJa else c.labelEn) else c.labelJa;
  let hint := if state.lang == "en" then (if c.hintEn == "" then c.hintJa else c.hintEn) else c.hintJa;
  let hintHtml := if hint == "" then ""
                  else sjoin(["<div class='hint'>", hesc(hint), "</div>"]);
  buttonHtml("choice", {tag: "choose", idx: i},
             sjoin([hesc(label), hintHtml]))

def choicesLoop(state, cs, i, acc) :=
  if i < arrLen(cs) then
    choicesLoop(state, cs, i + 1, sconcat(acc, renderChoice(state, arrGet(cs, i), i)))
  else acc

def renderChoices(state, step) :=
  let cs := step.choices;
  if arrLen(cs) == 0 then ""
  else sjoin(["<div class='choices'>", choicesLoop(state, cs, 0, ""), "</div>"])

def viewScene(state) :=
  let scene := sceneOf(state.sceneId);
  let step := stepAt(scene, state.beat);
  let bg := if step.bg == "" then "bg-pei" else step.bg;
  let advanceClick := if arrLen(step.choices) == 0
                      then sjoin([" data-msg=", msgAttr({tag: "advance"})]) else "";
  sjoin([
    "<div class='scene-bg ", bg, "'", advanceClick, ">",
    renderHud(state),
    renderSprites(step),
    renderChoices(state, step),
    renderDialogueBox(state, step),
    "</div>"
  ])

-- Ending screen
def endingTitle(id) :=
  match id with
  -- Act 1 endings (legacy / dead-ends)
  | "act1_clear"        => "第一幕 完 ― 劉邦"
  | "honest_anonymous"  => "END: 無名の生"
  | "cold_alone"        => "END: 孤独の冷血漢"
  | "xiangyu_act1_clear" => "第一幕 完 ― 項羽"
  | "phase2_placeholder" => "(Phase 2 で続く)"
  | "hanxin_act1_clear" => "第一幕 完 ― 韓信"
  | "hanxin_pride_dead" => "END: 誇りに殉ず"
  | "zhangliang_act1_clear" => "第一幕 完 ― 張良"
  | "zhangliang_obscure" => "END: 無名の遺民"
  | "xiaohe_act1_clear" => "第一幕 完 ― 蕭何"
  | "fanzeng_act1_clear" => "第一幕 完 ― 范増"
  | "face_read_failed" => "END: 顔相を読み損ねる"
  | "hanxin_beishui_lost" => "END: 背水に敗る"
  | "fanzeng_jade_diverged" => "★ 隠し END: 鴻門に劉邦死す (歴史改変)"
  | "xiangyu_wujiang" => "TRUE END ― 烏江自刎 (項羽 享年 31)"
  | "xiangyu_crossed_recluse" => "★ 隠し END: 江東に隠遁す (項羽 + 虞姫の骨)"
  | "liubang_died_emperor" => "TRUE END ― 漢高祖 崩御 (BCE 195, 享年 62)"
  | "hanxin_death_changle" => "TRUE END ― 長楽宮鐘室の最期 (韓信 BCE 196)"
  | "zhangliang_immortal_path" => "TRUE END ― 仙人の道へ (張良 BCE 189 頃)"
  | "xiaohe_died_chancellor" => "TRUE END ― 漢初の相国、賭けに勝つ (蕭何 BCE 193)"
  -- Act 2 main endings
  | "liubang_act2_clear" => "第二幕 完 ― 劉邦 (垓下前夜)"
  | "xiangyu_act2_clear" => "第二幕 完 ― 項羽 (鴻溝の和約)"
  | "hanxin_act2_clear" => "第二幕 完 ― 韓信 (垓下へ向かう)"
  | "zhangliang_act2_clear" => "第二幕 完 ― 張良 (十面埋伏)"
  | "xiaohe_act2_clear" => "第二幕 完 ― 蕭何 (共犯者として)"
  | "fanzeng_died_in_grief" => "END ― 范増、憤死す (享年 約七十五)"
  -- Act 2 dead-ends / divergences
  | "liubang_died_hongmen" => "END: 鴻門に死す"
  | "liubang_withered" => "END: 漢中に枯る"
  | "liubang_threeway" => "END: 三国鼎立の影"
  | "liubang_honggou_kept" => "END: 誠実の代償"
  | "xiangyu_julu_failed" => "END: 鉅鹿に敗る"
  | "xiangyu_killed_liu" => "END: 西楚帝国 (歴史改変)"
  | "hanxin_xizheng_legend" => "★ 隠し END: 韓信西征 ―― 東来之軍神"
  | "xiaohe_looter" => "END: 史に名を残さず"
  | "xiaohe_purity_death" => "END: 潔白の死"
  | _ => "END"

-- Map an ending id to a dramatic image asset, or "" for no image.
def endingImageFor(id) :=
  if id == "xiangyu_wujiang" then "/assets/end_wujiang.png"
  else if id == "xiangyu_crossed_recluse" then "/assets/end_yuji_dance.png"
  else if id == "hanxin_death_changle" then "/assets/end_changle.png"
  else if id == "hanxin_xizheng_legend" then "/assets/end_xizheng.png"
  else if id == "liubang_died_emperor" then "/assets/end_dafeng.png"
  else if id == "zhangliang_immortal_path" then "/assets/end_immortal.png"
  else if id == "xiaohe_died_chancellor" then "/assets/end_xiaohe.png"
  else if id == "fanzeng_died_in_grief" then "/assets/end_fanzeng.png"
  else if id == "fanzeng_jade_diverged" then "/assets/end_yuji_death.png"
  else ""

def viewEnding(state) :=
  let img := endingImageFor(state.endingId);
  let imgHtml := if img == "" then ""
    else sjoin(["<img class='end-image' src='", img, "' alt=''>"]);
  sjoin([
    "<div class='end-bg'>",
    imgHtml,
    "<div class='end-overlay'>",
    renderHud(state),
    "<h1 class='end-title'>",
    hesc(endingTitle(state.endingId)),
    "</h1>",
    "<div class='end-sub'>",
    "BCE 209 ─ 195, 「楚漢恋歌」より。<br>",
    "他のルートを試すこともできます。",
    "</div>",
    button("primary", {tag: "backToSelect"}, "主人公選択へ戻る"),
    "</div></div>"
  ])

-- Battle stub (no live entities yet — Phase 2 will populate)
def viewBattle(state) :=
  sjoin([
    "<div class='battle-bg'>",
    renderHud(state),
    "<canvas id='battleCanvas' width='640' height='400'></canvas>",
    "<div class='battle-hud'><span class='help'>WASD = move, Z = attack, ESC = retreat</span></div>",
    "<div class='battle-result'><div>(battle scaffolding ready — Phase 2)</div>",
    button("primary", {tag: "backToSelect"}, "戻る"),
    "</div></div>"
  ])

-- ── Mini-game views ───────────────────────────────────────────────
-- 顔相鑑定 — Liu Bang composes his face before 呂公
def faceLabel(part, v) :=
  if part == "eyes" then (if v == 0 then "穏やか" else if v == 1 then "普通" else "鋭い")
  else if part == "mouth" then (if v == 0 then "真剣" else if v == 1 then "微笑" else "笑い")
  else (if v == 0 then "卑屈" else if v == 1 then "普通" else "堂々")

def faceButton(part, v, cur) :=
  let mod := if v == cur then " active" else "";
  buttonMod("face", mod, {tag: "miniFace", part: part, value: v},
            faceLabel(part, v))

def faceRow(part, cur) :=
  btnRow("face", faceLabel(part, 99), sjoin([
    faceButton(part, 0, cur), faceButton(part, 1, cur), faceButton(part, 2, cur)
  ]))

def faceResultText(score) :=
  if score >= 5 then "「龍の相じゃ! 君は天下を取る器じゃ。我が娘・雉を娶ってもらいたい!」"
  else if score >= 3 then "「ふむ、上座へ。一杯やろう」"
  else "「ふん、田舎者の顔ぢゃ。下座でゆるりとな」"

def viewMiniFaceRead(state) :=
  let m := state.mini;
  let header := if m.faceShown then "呂公、お主の顔を読み取った――" else "呂公の前に進む。表情を組み立てよ。";
  let eyesRow := btnRow("face", "目つき:", sjoin([
    faceButton("eyes", 0, m.faceEyes), faceButton("eyes", 1, m.faceEyes), faceButton("eyes", 2, m.faceEyes)]));
  let mouthRow := btnRow("face", "口元:", sjoin([
    faceButton("mouth", 0, m.faceMouth), faceButton("mouth", 1, m.faceMouth), faceButton("mouth", 2, m.faceMouth)]));
  let poseRow := btnRow("face", "姿勢:", sjoin([
    faceButton("pose", 0, m.facePose), faceButton("pose", 1, m.facePose), faceButton("pose", 2, m.facePose)]));
  let actionBtn := if m.faceShown
    then sjoin(["<div class='mini-result'>",
                "<div class='mini-score'>呂公の評価: ", jstr(m.faceScore), " / 6</div>",
                "<div class='mini-line'>", hesc(faceResultText(m.faceScore)), "</div>",
                button("primary", {tag: "miniFaceDone"}, "続ける ▶"),
                "</div>"])
    else button("primary", {tag: "miniFaceShow"}, "呂公の前に進む");
  let body := sjoin([
    "<p class='mini-hint'>", header, "</p>",
    eyesRow, mouthRow, poseRow, actionBtn
  ]);
  sjoin([
    "<div class='scene-bg bg-banquet'>", renderHud(state),
    panel("mini", "顔相鑑定", body),
    "</div>"
  ])

-- 玉玦三度 — Fan Zeng raises the jade ring at Hongmen
def viewMiniJadeRing(state) :=
  let m := state.mini;
  let elapsed := m.ringNowMs - m.ringRoundStartMs;
  let inWindow := elapsed >= ringWindowStart && elapsed < ringWindowEnd;
  let progress := if elapsed > ringRoundMs then 100 else elapsed * 100 / ringRoundMs;
  let wStartPct := ringWindowStart * 100 / ringRoundMs;
  let wWidthPct := (ringWindowEnd - ringWindowStart) * 100 / ringRoundMs;
  let progressBar := ringBar(progress, wStartPct, wWidthPct);
  let status := if m.ringFinished then ""
                else if m.ringClickedThisRound then (if inWindow then "命中!" else "外れ……")
                else if inWindow then "今だ! クリックせよ" else "間 (ま) を見よ";
  let roundText := sjoin(["第 ", jstr(m.ringRound + 1), " 度の合図"]);
  let body := if m.ringFinished
    then sjoin(["<div class='mini-result'>",
                "<div class='mini-score'>項羽が応えた回数: ", jstr(m.ringHits), " / 3</div>",
                "<div class='mini-line'>",
                hesc(if m.ringHits >= 3 then "「斬る!」 項羽は劉邦を斬った。歴史は別の道へ。"
                     else if m.ringHits >= 1 then "項荘の剣舞に項羽はやや傾く。が、項伯が間に入る。"
                     else "「子犬の輩よ、共に謀るに足らず!」"),
                "</div>",
                button("primary", {tag: "miniRingDone"}, "続ける ▶"),
                "</div>"])
    else sjoin(["<p class='mini-hint'>", roundText, "</p>",
                progressBar,
                button("jade", {tag: "miniRingClick"}, "玉玦を上げる"),
                "<div class='mini-status'>", status, "</div>"]);
  sjoin([
    "<div class='scene-bg bg-tent'>", renderHud(state),
    panel("mini", "玉玦三度", body),
    "</div>"
  ])

-- 背水之陣 — Han Xin commands a 3-turn battle
def bsCard(turn, idx, label, hint) :=
  buttonHtml("card", {tag: "miniBsCard", card: idx},
    sjoin([
      "<div class='card-title'>", hesc(label), "</div>",
      "<div class='card-hint'>", hesc(hint), "</div>"
    ]))

def bsCardsForTurn(turn) :=
  if turn == 0 then sjoin([
    bsCard(0, 0, "高地に陣を敷く", "(常識的)"),
    bsCard(0, 1, "背水に陣を敷く", "(退路を断つ)"),
    bsCard(0, 2, "退却の構え", "(時を稼ぐ)")
  ])
  else if turn == 1 then sjoin([
    bsCard(1, 0, "黙して陣を敷く", "(兵に説明せず)"),
    bsCard(1, 1, "兵に布陣の意を説く", "(理解させる)"),
    bsCard(1, 2, "奇兵を先に出す", "(本陣手薄)")
  ])
  else sjoin([
    bsCard(2, 0, "正面で死守", "(五分五分)"),
    bsCard(2, 1, "後退して再編成", "(時を稼ぐ)"),
    bsCard(2, 2, "別動隊で趙本陣を奇襲", "(赤旗を立てる)")
  ])

def viewMiniBeishui(state) :=
  let m := state.mini;
  let logHtml := sjoin([
    if m.bsLog1 == "" then "" else sjoin(["<div class='bs-log'>布陣: ", hesc(m.bsLog1), "</div>"]),
    if m.bsLog2 == "" then "" else sjoin(["<div class='bs-log'>戦法: ", hesc(m.bsLog2), "</div>"]),
    if m.bsLog3 == "" then "" else sjoin(["<div class='bs-log'>決戦: ", hesc(m.bsLog3), "</div>"])
  ]);
  let body := if m.bsFinished
    then sjoin(["<div class='mini-result'>",
                "<div class='mini-score'>戦果: ", jstr(m.bsScore), " / 9 点</div>",
                "<div class='mini-line'>",
                hesc(if m.bsScore >= 7 then "完勝。趙軍崩壊。陳余、斬られた。「将軍の用兵、神の如し」"
                     else if m.bsScore >= 4 then "辛勝。兵は半ばを失ったが、なんとか趙を破った。"
                     else "敗北。漢軍は退却。韓信、面目を失う。"),
                "</div>",
                button("primary", {tag: "miniBsDone"}, "続ける ▶"),
                "</div>"])
    else sjoin([
      "<div class='bs-board'>",
      hpBar("hp", "漢 (韓信)", m.bsHanHp, 100), hpBar("hp", "趙 (陳余)", m.bsZhaoHp, 200),
      "</div>",
      "<div class='bs-turn'>第 ", jstr(m.bsTurn + 1), " ターン / 3</div>",
      "<div class='bs-cards'>", bsCardsForTurn(m.bsTurn), "</div>",
      logHtml
    ]);
  sjoin([
    "<div class='scene-bg bg-river'>", renderHud(state),
    panelMod("mini", "wide", "背水之陣", body),
    "</div>"
  ])

def viewMinigame(state) :=
  if state.mini.kind == "face_read" then viewMiniFaceRead(state)
  else if state.mini.kind == "jade_ring" then viewMiniJadeRing(state)
  else if state.mini.kind == "beishui" then viewMiniBeishui(state)
  else viewTitle(state)

-- ── LLM chat view ─────────────────────────────────────────────────
def renderChatBubble(m) :=
  let role := m.role;
  let bubbleClass := if role == "user" then "chat-bubble user" else "chat-bubble npc";
  sjoin([
    "<div class='", bubbleClass, "'>", hesc(m.text), "</div>"
  ])

def chatBubblesLoop(arr, i, acc) :=
  if i < arrLen(arr) then
    chatBubblesLoop(arr, i + 1, sconcat(acc, renderChatBubble(arrGet(arr, i))))
  else acc

def viewLlmChat(state) :=
  let l := state.llm;
  let bubbles := chatBubblesLoop(l.history, 0, "");
  let pendingHtml := if l.pending
    then "<div class='chat-pending'>… 考えている</div>" else "";
  let errorHtml := if l.lastError == "" then ""
    else sjoin(["<div class='chat-error'>", hesc(l.lastError), "</div>"]);
  let chatBody := sjoin([
    "<div class='chat-header'><span class='chat-npc-name' style='color:",
    l.npcColor, "'>", hesc(l.npcName), "</span>",
    " と話す ", button("icon", {tag: "llmEnd"}, "終わる ▶"),
    "</div>",
    "<div class='chat-history' id='chatHistory'>",
    bubbles, pendingHtml, errorHtml,
    "</div>",
    "<div class='chat-input-row'>",
    "<textarea id='chatInput' class='chat-input' rows='2' placeholder='ここに話しかける言葉を入力 (Enter で送信)' ",
    if l.pending then "disabled" else "",
    "></textarea>",
    "<button class='chat-send' id='chatSend' ", if l.pending then "disabled" else "",
    ">送信</button>",
    "</div>"
  ]);
  sjoin([
    "<div class='scene-bg bg-tent'>", renderHud(state),
    panel("chat", "", chatBody),
    "</div>"
  ])

-- ── TRPG aiResolve view ──────────────────────────────────────────
-- Player reads the situation, types their action, hits 送信. After the
-- LLM responds with {outcome, reasoning} we replace the input with the
-- verdict + reasoning + a 次へ button (which fires resolveAdvance).
def viewAiResolve(state) :=
  let r := state.resolve;
  let situation := if state.lang == "en" then r.situationEn else r.situationJa;
  let outcomeLabel := if r.resultOutcome == "good" then "✓ 説得成功"
                     else if r.resultOutcome == "ok" then "△ 微妙"
                     else if r.resultOutcome == "bad" then "✗ 失敗"
                     else "";
  let outcomeClass := if r.resultOutcome == "good" then "resolve-outcome good"
                     else if r.resultOutcome == "ok" then "resolve-outcome ok"
                     else if r.resultOutcome == "bad" then "resolve-outcome bad"
                     else "";
  let pendingHtml := if r.pending then "<div class='resolve-pending'>… LLM が判定中</div>" else "";
  let errorHtml := if r.lastError == "" then ""
                   else sjoin(["<div class='resolve-error'>", hesc(r.lastError), "</div>"]);
  let playerEcho := if r.playerText == "" then ""
                    else sjoin(["<div class='resolve-echo'><b>あなたの行動:</b> ", hesc(r.playerText), "</div>"]);
  let resultBlock := if r.resultOutcome == "" then ""
                     else sjoin([
                       "<div class='", outcomeClass, "'>", outcomeLabel, "</div>",
                       "<div class='resolve-reasoning'>", hesc(r.resultReasoning), "</div>",
                       button("primary", {tag: "resolveAdvance"}, "次へ ▶")
                     ]);
  let inputBlock := if r.resultOutcome != "" then ""
                    else sjoin([
                      "<div class='resolve-input-row'>",
                      "<textarea id='resolveInput' class='resolve-input' rows='3' placeholder='ここに行動を書く (Enter で送信)' ",
                      if r.pending then "disabled" else "",
                      "></textarea>",
                      "<button class='btn btn-primary' id='resolveSend' ",
                      if r.pending then "disabled" else "",
                      ">送信</button></div>"
                    ]);
  let body := sjoin([
    "<div class='resolve-situation'>", hesc(situation), "</div>",
    playerEcho, pendingHtml, errorHtml, resultBlock, inputBlock
  ]);
  sjoin([
    "<div class='scene-bg bg-tent'>", renderHud(state),
    panel("mini", "判定", body),
    "</div>"
  ])

-- ── Gallery view ─────────────────────────────────────────────────
def renderEndingRow(allObj, id) :=
  let achieved := hasKey(allObj, id) == 1;
  let mark := if achieved then "✓" else "□";
  let title := endingTitle(id);
  let cls := if achieved then "ending-row done" else "ending-row";
  sjoin([
    "<div class='", cls, "'><span class='mark'>", mark, "</span>",
    "<span class='title'>", hesc(title), "</span></div>"
  ])

def galleryLoop(allObj, ids, i, acc) :=
  if i < arrLen(ids) then
    galleryLoop(allObj, ids, i + 1, sconcat(acc, renderEndingRow(allObj, arrGet(ids, i))))
  else acc

def viewGallery(state) :=
  let allRaw := lsLoad("chuhan-endings");
  let allObj := if allRaw == null then {} else allRaw;
  let total := arrLen(allEndingIds);
  let achieved := countAchievedLoop(allObj, allEndingIds, 0, 0);
  sjoin([
    "<div class='title-bg'>",
    "<h1 style='font-size:36px;letter-spacing:6px;color:#c8a96a'>END ギャラリー</h1>",
    "<div class='sub'>達成: ", jstr(achieved), " / ", jstr(total), "</div>",
    "<div class='gallery-list'>",
    galleryLoop(allObj, allEndingIds, 0, ""),
    "</div>",
    button("primary", {tag: "closeGallery"}, "タイトルへ戻る"),
    "</div>"
  ])

-- Top-level view
-- Pick a BGM id from a scene's background. Empty string = no music.
def bgmForBg(bg) :=
  if bg == "bg-pei" then "village"
  else if bg == "bg-house" then "village"
  else if bg == "bg-pavilion" then "village"
  else if bg == "bg-court" then "court"
  else if bg == "bg-palace" then "court"
  else if bg == "bg-banquet" then "court"
  else if bg == "bg-altar" then "court"
  else if bg == "bg-camp" then "camp"
  else if bg == "bg-tent" then "camp"
  else if bg == "bg-battlefield" then "battle"
  else if bg == "bg-burning" then "battle"
  else if bg == "bg-jielo" then "battle"
  else if bg == "bg-yingyang" then "battle"
  else if bg == "bg-mountain" then "journey"
  else if bg == "bg-river" then "journey"
  else if bg == "bg-night" then "journey"
  else if bg == "bg-gorge" then "grief"
  else if bg == "bg-pengcheng" then "grief"
  else "village"


-- ── 群雄サンドボックス層 ─────────────────────────────────────────
include "Sandbox.leanjs"
