-- Standard outcome → continues the historical path
def liubangFaceOk := [
  say("bg-banquet", "呂公", colorLuFather,
    "「……君。上座へ。否、私の隣へ」",
    "“...You. Upstairs. No — beside me.“"),
  think("bg-banquet", "劉邦", colorLiu,
    "「いやぁ、こりゃ恐縮ですなぁ呂公!」",
    "“Hah, this is too much honor, Lord Lü!“",
    "悪くねえ。鋭く笑い堂々と座った――それで爺さんが俺を上座に呼んだ。",
    "Not bad. A sharp look, a slight smile, dignified posture — and he called me upstairs."),
  goScene("liubang_face_ok_continues")
]

def liubangFaceFailed := [
