def liubangFaceIntro := [
  narr("bg-banquet",
    "受付の役人は「賀銭一万」の札に目を丸くする。慌てて呂公本人が出てきて、劉邦の前に立った。",
    "The receptionist gapes at the ten-thousand card. Lord Lü himself comes out — and stands before Liu Bang."),
  duo("bg-banquet", "呂公", colorLuFather, "劉邦", colorLiu, 1,
    "「ふむ……君、面白い顔をしておる。少しその面を、ゆっくり見せてくれぬか」",
    "“Hmm... you have an interesting face. Let me read it slowly.“"),
  think("bg-banquet", "劉邦", colorLiu,
    "「(え、ええ、どうぞじっくりと)」",
    "“(Y-yes, take your time)“",
    "顔相見の好きな爺さんと聞いていた。これは『見せ方』で評価が分かれる。表情を組み立てろ。",
    "I heard he reads faces. The verdict depends on how I present myself. Compose the look."),
  miniStep("bg-banquet", "face_read",
    "liubang_face_dragon",   -- score 5-6
    "liubang_face_ok",        -- score 3-4
    "liubang_face_failed")    -- score 0-2
]

