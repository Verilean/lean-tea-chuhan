-- Han Xin Act 1 stub: 胯下の辱
def colorHan := "#7a6a1a"
def colorBully := "#6a3a1a"
def colorWasher := "#4a4a4a"
def colorPiaoYun := "#a08a5a"

def hanxinAct1 := [
  narr("bg-river", "紀元前 209 年、淮陰。一人の若者が長い剣を腰に下げて市場をうろついている。家は貧しく、母の喪のために身を立てる術もない。名は韓信。", "BCE 209, Huai-yin. A young man wanders the market with a long sword at his hip. Too poor to bury his mother, too proud to beg. His name is Han Xin."),
  think("bg-river", "韓信", colorHan,
    "「腹が減った。今日も、市の屠殺場に行けば、誰かが飯を恵んでくれるかもしれぬ」",
    "“Hungry. If I go to the slaughter market, perhaps someone will give me a meal.“",
    "だが、本当に欲しいのは飯ではない。誰かに、俺の中にある『これ』を見つけてほしい。",
    "But what I really want isn't food. It's for someone to see the 'this' inside me."),
  duo("bg-river", "屠殺の若者", colorBully, "韓信", colorHan, 1,
    "「おい、貧乏剣士。その腰の剣、お前に使う度胸があるか? あるならその剣で俺を刺してみろ。無いなら――俺の股の下を潜ってみせろ」",
    "“Hey, beggar swordsman. You got the guts to use that sword? If so, stab me. If not — crawl between my legs.“"),
  -- The famous choice
  chooseStep("bg-river", [
    Choice {
      labelJa: "剣を抜いてこの男を斬る",
      labelEn: "Draw the sword and cut him down",
      hintJa: "誇りは守れる。が、お前は罪人として処刑される。歴史は始まらない",
      hintEn: "Pride preserved — but you're executed as a murderer. History never starts",
      dKarma: 3, dWife: 0, dWifeFear: 0,
      dTrust: 0, dMinXin: 0,
      dBu: 2, dZhi: 0, dMei: 0, dZheng: -5,
      setFlag: "killed_bully", gotoScene: "hanxin_dead_end"
    },
    Choice {
      labelJa: "黙って、この男の股の下を潜る",
      labelEn: "Silently crawl between his legs",
      hintJa: "胯下之辱。市の者は皆、お前を笑う。だが、お前はその嘲笑を全部覚えておく",
      hintEn: "The Crotch Crawl. The whole market laughs. You memorize every laugh",
      dKarma: 0, dWife: 0, dWifeFear: 0,
      dTrust: 0, dMinXin: 0,
      dBu: 0, dZhi: 5, dMei: 0, dZheng: 3,
      setFlag: "endured_humiliation", gotoScene: "hanxin_piao_mu"
    }
  ])
]

def hanxinPiaoMu := [
  narr("bg-river",
    "数日後、韓信は河辺で漂母――綿打ちの老婆――に飯をもらった。", "Days later, by the river, Han Xin is given food by an old woman washing silk."),
  duo("bg-river", "韓信", colorHan, "漂母", colorWasher, 1,
    "「ばば様、いつかこの恩は千金で報いまする」",
    "“Old mother, one day I will repay this kindness with a thousand pieces of gold.“"),
  say("bg-river", "漂母", colorWasher,
    "「ふん、恩返しなど要らぬ。お前が立派な男になったかどうかだけ、見届けたい。あいにく私はもう長くないがな」",
    "“Hmph. I don't want repayment. I just want to see whether you become a man worth the rice. Not that I have much time left.“"),
  -- 漂雲 (original character) enters
  duo("bg-river", "韓信", colorHan, "漂雲", colorPiaoYun, 2,
    "「ばば様、孫が参りました。お疲れでしょう」",
    "“Grandmother, your granddaughter. You must be tired.“"),
  think("bg-river", "韓信", colorHan,
    "「……あなたが、漂母様の孫娘か」",
    "“...You are her granddaughter.“",
    "嫁か。俺には縁の無いものだ。だが、この娘の眼は商人のそれだ。世の中の値段が見える眼だ。",
    "A wife. Not for someone like me. But this girl's eyes — those are a merchant's eyes. Eyes that see the world's prices."),
  say("bg-river", "漂雲", colorPiaoYun,
    "「韓信殿でしたか。祖母が飯を上げてばかりで、家計が苦しゅうて参ります。あなた、その代わりに、一つだけ教えてくださらん? なぜ、あの股の下を潜ったの?」",
    "“You're Master Han Xin? Grandmother has been feeding you and our household budget is suffering. In return — tell me one thing. Why did you crawl?“"),
  chooseStep("bg-river", [
    Choice {
      labelJa: "「死ぬのが惜しかったからだ」と正直に答える",
      labelEn: "Honestly: “Because I did not want to die“",
      hintJa: "漂雲は微笑む。「正直な人ですね」",
      hintEn: "She smiles. “You're an honest man.“",
      dKarma: -1, dWife: 5, dWifeFear: 0,
      dTrust: 0, dMinXin: 0,
      dBu: 0, dZhi: 1, dMei: 1, dZheng: 1,
      setFlag: "honest_about_fear", gotoScene: ""
    },
    Choice {
      labelJa: "「一人を殺して命を捨てるより、万人を斬れる将になるためだ」と答える",
      labelEn: "“Better to become a general who slays ten thousand than throw my life away on one“",
      hintJa: "誇り高い答え。漂雲は「あなた、いつか身を滅ぼしますね」と呟く",
      hintEn: "Proud. Piao Yun murmurs: “You will, one day, destroy yourself.“",
      dKarma: 1, dWife: 2, dWifeFear: 0,
      dTrust: 0, dMinXin: 0,
      dBu: 1, dZhi: 2, dMei: 0, dZheng: -1,
      setFlag: "proud_ambition", gotoScene: ""
    }
  ]),
  narr("bg-river",
    "やがて韓信は項梁の軍に加わるが、項羽には認められず、何度も献策しては無視される日々。後に劉邦の軍に投じ、また小役人扱いされる。逃げようとした夜、月明かりの下、一人の役人が馬で追ってきた。蕭何である――。", "Han Xin joined Xiang Liang's army; under Xiang Yu his counsel went unheard. He defected to Liu Bang's army, where he was again treated as a minor clerk. One moonlit night, fleeing in despair, he was chased down by a single official on horseback — Xiao He."),
  goScene("hanxin_act2")
]

def hanxinDeadEnd := [
  narr("bg-river", "韓信は剣を抜き、屠殺の若者を斬った。罪人として捕えられ、その日のうちに処刑。淮陰の名も無き貧乏剣士は、こうして史に名を残すことなく消えた。", "Han Xin drew his sword and cut the bully down. Arrested as a murderer, executed by sundown. The nameless poor swordsman of Huai-yin vanished without ever entering history."),
  endingStep("hanxin_pride_dead")
]

